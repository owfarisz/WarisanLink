generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id            Int           @id @default(autoincrement())
  name          String        @unique @db.VarChar(100)
  slug          String        @unique @db.VarChar(100)
  description   String?
  iconName      String?       @db.VarChar(50)
  colorHex      String?       @db.VarChar(7)
  createdAt     DateTime      @default(now())

  destinations  Destination[]
}

model Destination {
  id                Int            @id @default(autoincrement())
  slug              String         @unique @db.VarChar(200)
  name              String         @db.VarChar(200)
  city              String         @db.VarChar(100)
  province          String         @db.VarChar(100)
  categoryId        Int
  shortDesc         String         @db.VarChar(500)
  culturalMeaning   String
  localHistory      String
  malaysiaConnection String
  localEtiquette    String?
  coverImageUrl     String?        @db.VarChar(500)
  galleryUrls       Json?
  viewCount         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  category          Category       @relation(fields: [categoryId], references: [id])
  accessCompass     AccessCompass?

  @@index([categoryId])
  @@index([province])
}

model AccessCompass {
  id                Int          @id @default(autoincrement())
  destinationId     Int          @unique
  nearestGateway    String       @db.VarChar(200)
  entryPoint        String?      @db.VarChar(300)
  distanceKm        Float?
  accessLevel       AccessLevel  @default(MODERATE)
  weatherSummary    String?      @db.VarChar(500)
  bestTimeToVisit   String?      @db.VarChar(300)
  travelNotes       String?
  safetyNotes       String?
  latitude          Float?
  longitude         Float?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  destination       Destination  @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}

enum AccessLevel {
  EASY
  MODERATE
  REMOTE
}

model VisitHistory {
  id            Int      @id @default(autoincrement())
  sessionId     String   @db.VarChar(100)
  destinationId Int
  visitedAt     DateTime @default(now())

  @@index([sessionId])
  @@index([visitedAt])
}
