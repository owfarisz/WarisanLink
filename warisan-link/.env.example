# ── Docker Port Mapping ───────────────────────────────────────
# VPS: FRONTEND_PORT=8082 (Cloudflare Tunnel target)
# Local: ubah ke FRONTEND_PORT=8080 agar tidak konflik
FRONTEND_PORT=8082

# Postgres host port (5432 dan 5433 sudah dipakai proyek lain di VPS)
DB_PORT=5434

# ── PostgreSQL Credentials ────────────────────────────────────
DB_USER=warisan_user
DB_PASSWORD=StrongPassword!123
DB_NAME=warisan_link
